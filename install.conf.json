[
  {
    "link": {
      "~/": {
        "relink": true,
        "glob": true,
        "path": "dotconf/*",
        "prefix": "."
      },
      "~/.config/nvim/": {
        "create": true,
        "relink": true,
        "glob": true,
        "path": "nvim/*"
      },
      "~/.config/kitty/": {
        "create": true,
        "relink": true,
        "glob": true,
        "path": "kitty/*"
      },
      "~/.local/bin/": {
        "create": true,
        "relink": true,
        "glob": true,
        "path": "scripts/*"
      }
    }
  }
]
